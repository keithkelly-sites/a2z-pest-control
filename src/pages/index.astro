---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pittsburgh Pest Control - A2Z Pest Control LLC" description="Family-owned pest control serving Allegheny, Butler, and Washington Counties since 1993. Free phone estimates, unmarked vehicles, no pressure sales. Call 412-854-2224.">

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: oklch(0.42 0.16 256);">
    <div class="absolute inset-0 opacity-[0.08]" style="background: repeating-linear-gradient(135deg, transparent 0 12px, oklch(0.52 0.16 256) 12px 13px);"></div>
    <div class="relative mx-auto" style="max-width: var(--content-max-width); padding: 120px var(--padding-x-mobile) 80px;">
      <div class="max-w-2xl">
        <div class="w-12 h-[3px] mb-8" style="background: var(--color-accent);"></div>
        <h1 class="text-white mb-6">Pittsburgh's Trusted Pest Control. Since 1993.</h1>
        <p class="text-white/80 text-lg mb-10 leading-relaxed max-w-xl">Family-owned, discreet, and on time. We treat your home like our own. Serving Allegheny, Butler, and Washington Counties.</p>
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <a
            href="tel:4128542224"
            class="inline-flex items-center gap-2 text-base font-semibold px-7 py-3.5"
            style="background: var(--color-accent); color: var(--color-foreground); border-radius: var(--radius-full); font-family: var(--font-body);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call for a Free Estimate
          </a>
          <a href="/services" class="text-white/80 hover:text-white text-sm font-medium underline underline-offset-4" style="font-family: var(--font-body);">See our services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section style="background: var(--color-muted);">
    <div class="mx-auto" style="max-width: var(--content-max-width); padding: 48px var(--padding-x-mobile);">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-6">
        <div class="flex flex-col items-center text-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary);"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          <p class="text-sm font-medium" style="color: var(--color-foreground); font-family: var(--font-body);">30+ Years Experience</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary);"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          <p class="text-sm font-medium" style="color: var(--color-foreground); font-family: var(--font-body);">Family-Owned & Operated</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary);"><rect x="1" y="3" width="15" height="13" rx="2" ry="2"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <p class="text-sm font-medium" style="color: var(--color-foreground); font-family: var(--font-body);">Unmarked Vehicles</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary);"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          <p class="text-sm font-medium" style="color: var(--color-foreground); font-family: var(--font-body);">Screened & Trained Employees</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3 col-span-2 md:col-span-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <p class="text-sm font-medium" style="color: var(--color-foreground); font-family: var(--font-body);">Free Phone Estimates</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section style="background: var(--color-background);">
    <div class="mx-auto" style="max-width: var(--content-max-width); padding: var(--section-padding-y) var(--padding-x-mobile);">
      <h2 class="mb-4">What We Handle</h2>
      <p class="text-base mb-10 max-w-2xl" style="color: var(--color-muted-foreground); font-family: var(--font-body);">A2Z Pest Control treats the most common household and seasonal pests in the Pittsburgh area. Call for a free phone estimate. We'll confirm whether we're the right fit before you schedule anything.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Ants</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Carpenter ants, odorous house ants, and pavement ants.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Rodents</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Mice, rats, and other rodents invading your home.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Roaches & Boxelder Bugs</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Cockroach infestations and seasonal boxelder bug invasions.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Centipedes & Millipedes</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">House centipedes and millipedes found in basements and damp areas.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Stinging Insects</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Wasps, yellow jackets, hornets, and bumble bees. Exterior treatment only.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Moths</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Indian meal moths infesting stored food products.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Fleas</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Flea infestations in homes with pets or wildlife activity.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Silverfish & Earwigs</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Silverfish in humid areas and earwigs around foundations.</p>
        </div>
        <div class="bg-white p-6 border-t-2" style="border-color: var(--color-primary); border-radius: var(--radius);">
          <h3 class="mb-2">Carpenter Bees</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground);">Carpenter bees boring into wood trim, decks, and fascia boards.</p>
        </div>
      </div>

      <div class="mt-8 p-5 border-l-[3px]" style="border-color: var(--color-accent); background: oklch(0.95 0.04 47); border-radius: 0 var(--radius) var(--radius) 0;">
        <p class="text-sm italic" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Note: We are not currently taking on new termite work this year.</p>
      </div>

      <div class="mt-8">
        <a href="/services" class="text-sm font-medium underline underline-offset-4" style="color: var(--color-primary); font-family: var(--font-body);">View full service details</a>
      </div>
    </div>
  </section>

  <!-- About Strip -->
  <section class="relative overflow-hidden" style="background: oklch(0.42 0.16 256);">
    <div class="mx-auto grid md:grid-cols-2 gap-0" style="max-width: var(--content-max-width);">
      <div class="aspect-[4/5] md:aspect-auto">
        <img
          src="/images/unadjustednonraw_thumb_a1e1.jpg"
          alt="Our Family"
          class="w-full h-full object-cover object-top"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col justify-center" style="padding: var(--section-padding-y-mobile) var(--padding-x-mobile); color: #ffffff;">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] mb-4" style="color: var(--color-accent); font-family: var(--font-body);">About A2Z Pest Control</p>
        <h2 class="text-white mb-6">Family-Owned Since 1993</h2>
        <p class="text-white/80 leading-relaxed mb-8" style="font-family: var(--font-body);">A2Z Pest Control LLC is a local, family-owned business. Since 1993, we've treated thousands of homes in Allegheny, Butler, and Washington Counties. As parents and pet owners, we understand what's essential in choosing a pest control company. At A2Z Pest Control LLC, we treat your home like our own. Safety is our priority, letting you feel confident the work is done right.</p>
        <a href="/about" class="text-sm font-medium underline underline-offset-4" style="color: var(--color-accent); font-family: var(--font-body);">Our full story</a>
      </div>
    </div>
  </section>

  <!-- Service Area + CTA -->
  <section style="background: var(--color-muted);">
    <div class="mx-auto text-center" style="max-width: var(--content-max-width); padding: var(--section-padding-y) var(--padding-x-mobile);">
      <div class="w-12 h-[3px] mx-auto mb-8" style="background: var(--color-accent);"></div>
      <h2 class="mb-4">Serving Pittsburgh and Surrounding Counties</h2>
      <p class="text-base mb-10 max-w-xl mx-auto" style="color: var(--color-muted-foreground); font-family: var(--font-body);">We cover Allegheny, Butler, and Washington Counties. If you're not sure whether we service your area, call us. We're happy to check.</p>
      <a href="tel:4128542224" class="inline-block text-4xl md:text-5xl font-bold tracking-tight mb-3" style="color: var(--color-primary); font-family: var(--font-display);">412-854-2224</a>
      <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Phones answered Monday-Friday 8am-3pm</p>
    </div>
  </section>

  <!-- Google Reviews -->
  <section style="background: var(--color-background);">
    <div class="mx-auto text-center" style="max-width: var(--content-max-width); padding: 48px var(--padding-x-mobile);">
      <a
        href="https://www.google.com/search?q=a2z+pest+control&oq=a2z+pest+con&gs_lcrp=EgZjaHJvbWUqDAgAEAAYQxiABBiKBTIMCAAQABhDGIAEGIoFMgYIARBFGDkyDQgCEC4YrwEYxwEYgAQyBwgDEAAYgAQyCAgEEAAYFhgeMggIBRAAGBYYHjIGCAYQRRg8MgYIBxBFGD3SAQgyOTA1ajBqN6gCALACAA&sourceid=chrome&ie=UTF-8#lrd=0x8834fa25b9efdde3:0x77d635f21777909,1,,,,"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium border-2"
        style="border-color: var(--color-primary); color: var(--color-primary); border-radius: var(--radius-full); font-family: var(--font-body);"
      >
        See what Pittsburgh homeowners say about A2Z Pest Control
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>
    </div>
  </section>

</Layout>
