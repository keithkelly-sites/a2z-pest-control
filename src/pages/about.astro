---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us - A2Z Pest Control LLC" description="A2Z Pest Control LLC has been a family-owned pest control business in Pittsburgh since 1993, serving Allegheny, Butler, and Washington Counties.">

  <!-- Page Header -->
  <section class="relative overflow-hidden" style="background: oklch(0.42 0.16 256);">
    <div class="absolute inset-0 opacity-[0.06]" style="background: repeating-linear-gradient(135deg, transparent 0 12px, oklch(0.52 0.16 256) 12px 13px);"></div>
    <div class="relative mx-auto" style="max-width: var(--content-max-width); padding: 80px var(--padding-x-mobile);">
      <h1 class="text-white mb-3">About A2Z Pest Control</h1>
      <p class="text-white/70 text-lg" style="font-family: var(--font-body);">Locally owned and operated in Pittsburgh since 1993.</p>
    </div>
  </section>

  <!-- Our Story -->
  <section style="background: var(--color-background);">
    <div class="mx-auto grid md:grid-cols-2 gap-0" style="max-width: var(--content-max-width);">
      <div class="aspect-[3/4] md:aspect-auto">
        <img
          src="/images/unadjustednonraw_thumb_a1e1.jpg"
          alt="Our Family"
          class="w-full h-full object-cover object-top"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col justify-center" style="padding: var(--section-padding-y-mobile) var(--padding-x-mobile);">
        <h2 class="mb-6">Treating Pittsburgh Homes Since 1993</h2>
        <p class="leading-relaxed mb-4" style="color: var(--color-muted-foreground); font-family: var(--font-body);">A2Z Pest Control LLC is a local, family-owned business. Since 1993, we've treated thousands of homes in Allegheny, Butler, and Washington Counties.</p>
        <p class="leading-relaxed mb-4" style="color: var(--color-muted-foreground); font-family: var(--font-body);">As parents and pet owners, we understand what's essential in choosing a pest control company. At A2Z Pest Control LLC, we treat your home like our own.</p>
        <p class="leading-relaxed" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Safety is our priority, letting you feel confident the work is done right.</p>
      </div>
    </div>
  </section>

  <!-- Why Choose A2Z -->
  <section style="background: var(--color-muted);">
    <div class="mx-auto" style="max-width: var(--content-max-width); padding: var(--section-padding-y) var(--padding-x-mobile);">
      <h2 class="text-center mb-12">What You Can Expect</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">30+ Years of Experience</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">In business since 1993, serving thousands of Pittsburgh area homes.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">Family-Owned</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">We are parents and pet owners ourselves. We understand the stakes when it comes to pest control safety.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">Screened & Trained Employees</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Every technician is vetted before stepping into a customer's home.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">No Pressure Sales</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">We give you the information, you make the call. No upsells, no scare tactics.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">On-Time Appointments</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Respecting your schedule is part of the job.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">Unmarked Vehicles</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Discreet service for customers who prefer privacy.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">Free Phone Estimates</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Call and we'll tell you what we can do before you commit to anything.</p>
        </div>
        <div class="border-l-2 pl-6 py-3" style="border-color: var(--color-accent);">
          <h3 class="mb-2 text-base font-semibold" style="font-family: var(--font-display);">Budget-Friendly</h3>
          <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Competitive pricing for Pittsburgh area homeowners.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours & Service Area -->
  <section style="background: var(--color-background);">
    <div class="mx-auto grid md:grid-cols-2 gap-10" style="max-width: var(--content-max-width); padding: var(--section-padding-y) var(--padding-x-mobile);">
      <div>
        <h3 class="mb-4">Business Hours</h3>
        <p class="text-sm leading-relaxed mb-2" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Phones answered Monday-Friday 8am-3pm</p>
        <p class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Closed Saturday and Sunday</p>
      </div>
      <div>
        <h3 class="mb-4">Service Area</h3>
        <ul class="space-y-2">
          <li class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Allegheny County</li>
          <li class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Butler County</li>
          <li class="text-sm" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Washington County</li>
        </ul>
        <p class="text-sm mt-4" style="color: var(--color-muted-foreground); font-family: var(--font-body);">Not sure if you're in our coverage area? Give us a call.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background: oklch(0.42 0.16 256);">
    <div class="mx-auto text-center" style="max-width: var(--content-max-width); padding: var(--section-padding-y) var(--padding-x-mobile);">
      <div class="w-12 h-[3px] mx-auto mb-8" style="background: var(--color-accent);"></div>
      <h2 class="text-white mb-6">Call Us Today</h2>
      <a href="tel:4128542224" class="inline-block text-4xl md:text-5xl font-bold tracking-tight text-white mb-3" style="font-family: var(--font-display);">412-854-2224</a>
      <p class="text-sm text-white/50" style="font-family: var(--font-body);">Phones answered Monday-Friday 8am-3pm</p>
    </div>
  </section>

</Layout>
