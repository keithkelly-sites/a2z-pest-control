---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const businessName = 'A2Z Pest Control LLC';
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <script async src="https://api.keithkelly.dev/d/s"></script>
  <script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init({endpoint:"https://api.keithkelly.dev/d/e"})</script>
</head>
<body>
  <!-- Navigation -->
  <header class="sticky top-0 z-50 on-primary" style="background: #29303a;">
    <nav class="mx-auto flex items-center justify-between" style="max-width: var(--content-max-width); padding: 16px var(--padding-x-mobile);">
      <a href="/" class="flex items-center gap-2 text-lg font-bold text-white tracking-tight" style="font-family: var(--font-display);">
        <img src="/images/bug-mascot.png" alt="A2Z Pest Control" class="h-9 w-auto" />
        <span>A2Z Pest Control</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium tracking-wide',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-white'
                : 'text-white/75 hover:text-white'
            ]}
            style="font-family: var(--font-body); transition: color 0.15s ease;"
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:4128542224"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5"
          style="background: var(--color-accent-bright); color: var(--color-foreground); border-radius: var(--radius-full); font-family: var(--font-body);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call 412-854-2224
        </a>
      </div>

      <!-- Mobile menu toggle -->
      <button id="menu-toggle" class="md:hidden p-2 text-white" aria-label="Toggle menu" aria-expanded="false">
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        <svg id="menu-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="hidden md:hidden on-primary" style="background: #232a33;">
      <div class="flex flex-col px-6 py-4 gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'py-3 text-base font-medium border-b border-white/10',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-white'
                : 'text-white/75'
            ]}
            style="font-family: var(--font-body);"
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:4128542224"
          class="mt-3 mb-1 inline-flex items-center justify-center gap-2 text-base font-semibold px-5 py-3"
          style="background: var(--color-accent-bright); color: var(--color-foreground); border-radius: var(--radius-full); font-family: var(--font-body);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call 412-854-2224
        </a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="on-primary" style="background: var(--color-primary-dark);">
    <div class="mx-auto grid gap-10 md:grid-cols-3 py-16" style="max-width: var(--content-max-width); padding-left: var(--padding-x-mobile); padding-right: var(--padding-x-mobile);">
      <div>
        <p class="text-lg font-bold tracking-tight mb-3" style="font-family: var(--font-display);">A2Z Pest Control LLC</p>
        <p class="text-sm text-white/70 leading-relaxed">Family-owned pest control serving Pittsburgh since 1993.</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-white/50 mb-4" style="font-family: var(--font-body);">Quick Links</p>
        <nav class="flex flex-col gap-2.5">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm text-white/70 hover:text-white" style="font-family: var(--font-body); transition: color 0.15s ease;">
              {link.label}
            </a>
          ))}
        </nav>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-white/50 mb-4" style="font-family: var(--font-body);">Contact</p>
        <div class="flex flex-col gap-2.5 text-sm">
          <a href="tel:4128542224" class="text-white/70 hover:text-white" style="transition: color 0.15s ease;">412-854-2224</a>
          <a href="mailto:a2zpestcontrolllc@gmail.com" class="text-white/70 hover:text-white" style="transition: color 0.15s ease;">a2zpestcontrolllc@gmail.com</a>
          <p class="text-white/50">Mon-Fri 8am-3pm</p>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 py-6 text-center">
      <p class="text-xs text-white/40" style="font-family: var(--font-body);">&copy; 2026 A2Z Pest Control LLC. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle?.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
  });
</script>
