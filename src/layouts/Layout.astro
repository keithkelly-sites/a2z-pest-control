---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "A2Z Pest Control has set the standard for pest control in the Pittsburgh area. Family-owned since 1993. Dependable, budget friendly, unmarked vehicles.", ogImage = "/images/logo.png" } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL.href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImageURL.href} />
  <meta property="og:site_name" content="A2Z Pest Control LLC" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
  <Font cssVariable="--font-bebas" preload />
  <Font cssVariable="--font-inter" preload />
  <ClientRouter />
</head>
<body>
  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo-link">
        <img src="/images/mascot.png" alt="" class="logo-mascot" width="52" height="76" />
        <span class="logo-text">A2Z <span class="logo-text-sub">Pest Control</span></span>
      </a>
      <nav class="main-nav" aria-label="Main navigation">
        <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>
        <ul id="nav-menu" class="nav-list nav-list--desktop">
          <li><a href="/" class:list={[{ active: currentPath === '/' }]} aria-current={currentPath === '/' ? 'page' : undefined}>Home</a></li>
          <li><a href="/services" class:list={[{ active: currentPath === '/services' || currentPath === '/services/' }]} aria-current={currentPath === '/services' || currentPath === '/services/' ? 'page' : undefined}>Services</a></li>
          <li><a href="/about" class:list={[{ active: currentPath === '/about' || currentPath === '/about/' }]} aria-current={currentPath === '/about' || currentPath === '/about/' ? 'page' : undefined}>About</a></li>
          <li><a href="/contact" class:list={[{ active: currentPath === '/contact' || currentPath === '/contact/' }]} aria-current={currentPath === '/contact' || currentPath === '/contact/' ? 'page' : undefined}>Contact</a></li>
        </ul>
        <a href="tel:412-854-2224" class="header-cta">412-854-2224</a>
      </nav>
    </div>
  </header>

  <!-- Mobile menu overlay — outside header to avoid backdrop-filter containing block -->
  <div id="mobile-menu" class="mobile-overlay" aria-hidden="true">
    <button class="mobile-overlay-close" aria-label="Close menu">
      <span aria-hidden="true">&times;</span>
    </button>
    <ul class="mobile-overlay-list">
      <li><a href="/" class:list={[{ active: currentPath === '/' }]} aria-current={currentPath === '/' ? 'page' : undefined}>Home</a></li>
      <li><a href="/services" class:list={[{ active: currentPath === '/services' || currentPath === '/services/' }]} aria-current={currentPath === '/services' || currentPath === '/services/' ? 'page' : undefined}>Services</a></li>
      <li><a href="/about" class:list={[{ active: currentPath === '/about' || currentPath === '/about/' }]} aria-current={currentPath === '/about' || currentPath === '/about/' ? 'page' : undefined}>About</a></li>
      <li><a href="/contact" class:list={[{ active: currentPath === '/contact' || currentPath === '/contact/' }]} aria-current={currentPath === '/contact' || currentPath === '/contact/' ? 'page' : undefined}>Contact</a></li>
    </ul>
    <a href="tel:412-854-2224" class="mobile-overlay-cta">412-854-2224</a>
  </div>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo-group">
            <img src="/images/mascot.png" alt="" class="footer-mascot" width="52" height="76" />
            <span class="footer-logo-text">A2Z <span class="footer-logo-sub">Pest Control</span></span>
          </div>
          <p class="footer-tagline">Family-owned pest control serving the Pittsburgh area since 1993.</p>
        </div>
        <nav class="footer-links" aria-label="Footer navigation">
          <h4>Navigation</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </nav>
        <div class="footer-contact">
          <h4>Get in Touch</h4>
          <address>
            <a href="tel:412-854-2224">412-854-2224</a>
            <a href="mailto:a2zpestcontrolllc@gmail.com">a2zpestcontrolllc@gmail.com</a>
            <span>Mon&ndash;Fri, 8am&ndash;3pm</span>
          </address>
        </div>
        <div class="footer-service-area">
          <h4>Service Area</h4>
          <p>Allegheny County<br />Butler County<br />Washington County</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} A2Z Pest Control LLC. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    function initMobileNav() {
      const toggle = document.querySelector('.nav-toggle');
      const overlay = document.querySelector('#mobile-menu');
      if (!toggle || !overlay) return;

      function closeMenu() {
        toggle.setAttribute('aria-expanded', 'false');
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
      }

      // Replace old listener by cloning the node
      const freshToggle = toggle.cloneNode(true) as Element;
      toggle.replaceWith(freshToggle);

      freshToggle.addEventListener('click', () => {
        const expanded = freshToggle.getAttribute('aria-expanded') === 'true';
        freshToggle.setAttribute('aria-expanded', String(!expanded));
        overlay.classList.toggle('open');
        overlay.setAttribute('aria-hidden', String(expanded));
      });

      // Close button
      const closeBtn = overlay.querySelector('.mobile-overlay-close');
      if (closeBtn) closeBtn.addEventListener('click', closeMenu);

      // Close menu when a nav link is clicked
      overlay.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    }

    function initReveals() {
      const reveals = document.querySelectorAll('.reveal:not(.visible)');
      if (reveals.length === 0) return;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });
      reveals.forEach(el => observer.observe(el));
    }

    function initPage() {
      initMobileNav();
      initReveals();
    }

    // Run when DOM is ready and on Astro client-side navigations
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPage);
    } else {
      initPage();
    }
    document.addEventListener('astro:after-swap', initPage);
  </script>
</body>
</html>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: oklch(0.08 0.015 145 / 0.85);
    backdrop-filter: blur(16px) saturate(1.4);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(var(--max-width), 100% - var(--space-md) * 2);
    margin-inline: auto;
    padding-block: var(--space-sm);
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .logo-mascot {
    height: 36px;
    width: auto;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green);
    line-height: 1;
  }

  .logo-text-sub {
    color: var(--white);
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .nav-list {
    display: flex;
    gap: var(--space-xs);

    a {
      display: block;
      padding: 0.5rem 1rem;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-dim);
      border-radius: var(--radius);
      transition: color 0.2s, background 0.2s;

      &:hover, &.active {
        color: var(--green);
        background: var(--green-glass);
      }
    }
  }

  .header-cta {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    color: var(--green);
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--green-dim);
    border-radius: var(--radius);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;

    &:hover {
      background: var(--green);
      color: var(--black);
    }
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
  }

  .nav-toggle-bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    @media (prefers-reduced-motion: no-preference) {
      transition: transform 0.3s, opacity 0.3s;
    }
  }

  .nav-toggle[aria-expanded="true"] {
    .nav-toggle-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle-bar:nth-child(2) { opacity: 0; }
    .nav-toggle-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
      position: relative;
      z-index: 300;
    }

    .nav-list--desktop {
      display: none;
    }

    .header-cta {
      display: none;
    }
  }

  /* Mobile overlay — lives outside header to avoid backdrop-filter containing block */
  .mobile-overlay {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-overlay {
      display: flex;
      position: fixed;
      inset: 0;
      z-index: 200;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--space-lg);
      background: oklch(0.05 0.01 145 / 0.97);
      backdrop-filter: blur(20px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;

      &.open {
        opacity: 1;
        pointer-events: auto;
      }
    }

    .mobile-overlay-close {
      position: absolute;
      top: var(--space-sm);
      right: var(--space-md);
      font-size: 2rem;
      line-height: 1;
      color: var(--text-dim);
      padding: 0.25rem 0.5rem;
      transition: color 0.2s;

      &:hover {
        color: var(--white);
      }
    }

    .mobile-overlay-list {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
      list-style: none;

      a {
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--white);
        transition: color 0.2s;

        &:hover, &.active {
          color: var(--green);
        }
      }
    }

    .mobile-overlay-cta {
      font-family: var(--font-display);
      font-size: 1.3rem;
      letter-spacing: 0.05em;
      color: var(--green);
      padding: 0.6rem 1.5rem;
      border: 1px solid var(--green-dim);
      border-radius: var(--radius);
      transition: background 0.2s, color 0.2s;

      &:hover {
        background: var(--green);
        color: var(--black);
      }
    }
  }

  /* Footer */
  .site-footer {
    background: var(--black-pure);
    border-top: 1px solid var(--border);
    padding-block: var(--space-xl) var(--space-lg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-lg);
  }

  .footer-logo-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-sm);
  }

  .footer-mascot {
    height: 32px;
    width: auto;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green);
    line-height: 1;
  }

  .footer-logo-sub {
    color: var(--white);
  }

  .footer-tagline {
    color: var(--text-dim);
    font-size: 0.9rem;
    max-width: 280px;
  }

  .footer-grid h4 {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--green);
    margin-bottom: var(--space-sm);
  }

  .footer-links ul, .footer-contact address {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-style: normal;

    a, li, span {
      font-size: 0.9rem;
      color: var(--text-dim);
      transition: color 0.2s;
    }

    a:hover {
      color: var(--green);
    }
  }

  .footer-service-area p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.8;
  }

  .footer-bottom {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);

    p {
      font-size: 0.8rem;
      color: var(--text-faint);
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
